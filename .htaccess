# 禁止直接访问配置文件
<FilesMatch "^(config|database|common|function|base|includes|class|lib|core)\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 禁止直接访问包含目录
<DirectoryMatch "^(includes|class|lib|core)">
    Order deny,allow
    Deny from all
</DirectoryMatch>

# 禁止访问备份文件和敏感文件
